@echo off
chcp 65001 >nul
title 米家设备Token提取工具
echo ================================================================
echo   米家设备 Token 提取工具
echo ================================================================
echo.
echo   操作步骤：
echo   1. 选择登录方式：输入 p（密码）或 q（二维码扫码）
echo   2. 如果选 q：用手机米家APP扫描弹出的二维码
echo   3. 登录成功后选择服务器：输入 cn（中国服务器）
